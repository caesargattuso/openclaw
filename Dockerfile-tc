FROM hub-bigdata.17usoft.com/bigdata/python:3.12

ARG NODE_VERSION=v25.6.0
ARG OPENCLAW_VERSION=2026.2.26

# 创建 openclaw 用户
RUN groupadd -r openclaw && \
    useradd -r -g openclaw -m -s /bin/bash openclaw

# 安装 Node.js、pnpm、openclaw
RUN wget -q https://nodejs.org/dist/${NODE_VERSION}/node-${NODE_VERSION}-linux-x64.tar.gz && \
    tar -xzf node-${NODE_VERSION}-linux-x64.tar.gz -C /usr/local/ && \
    rm -f node-${NODE_VERSION}-linux-x64.tar.gz && \
    ln -sf /usr/local/node-${NODE_VERSION}-linux-x64 /usr/local/node

ENV PATH=/usr/local/node/bin:$PATH
ENV PNPM_HOME=/usr/local/pnpm
ENV PATH=$PATH:$PNPM_HOME
ENV NODE_ENV=production

RUN npm install -g --registry=https://registry.npmmirror.com pnpm

WORKDIR /app

COPY --chown=openclaw:openclaw package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY --chown=openclaw:openclaw ui/package.json ./ui/package.json
COPY --chown=openclaw:openclaw patches ./patches
COPY --chown=openclaw:openclaw scripts ./scripts

RUN NODE_OPTIONS=--max-old-space-size=2048 pnpm install --frozen-lockfile

RUN apt-get update && \
      DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends gosu xvfb supervisor && \
      mkdir -p /home/openclaw/.cache/ms-playwright && \
      PLAYWRIGHT_BROWSERS_PATH=/home/openclaw/.cache/ms-playwright \
      node /app/node_modules/playwright-core/cli.js install --with-deps chromium && \
      chown -R openclaw:openclaw /home/openclaw/.cache/ms-playwright && \
      apt-get clean && \
      rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

RUN pip install \
    numpy \
    pandas \
    matplotlib \
    seaborn \
    scikit-learn \
    requests \
    beautifulsoup4 \
    pillow \
    openpyxl \
    python-docx \
    pyautogui \
    opencv-python \
    playwright \
    html2text \
    pyyaml

# 安装openclaw
#RUN npm install -g --registry=https://registry.npmmirror.com openclaw@${OPENCLAW_VERSION}

COPY --chown=openclaw:openclaw . .
RUN for dir in /app/extensions /app/.agent /app/.agents; do \
      if [ -d "$dir" ]; then \
        find "$dir" -type d -exec chmod 755 {} +; \
        find "$dir" -type f -exec chmod 644 {} +; \
      fi; \
    done
RUN pnpm build
# Force pnpm for UI build (Bun may fail on ARM/Synology architectures)
ENV OPENCLAW_PREFER_PNPM=1
RUN pnpm ui:build

# Expose the CLI binary without requiring npm global writes as non-root.
RUN ln -sf /app/openclaw.mjs /usr/local/bin/openclaw \
 && chmod 755 /app/openclaw.mjs

COPY --chown=openclaw:openclaw openclaw.json /openclaw.json
COPY --chmod=755 entrypoint.sh /entrypoint.sh

ENV SSO_ENV=qa
WORKDIR /scripts/browser_daemon
RUN wget http://oss.17usoft.com/toca-visual-express/product/im/8da3772a4b434a42ae1dfd6aeb442d79_585951698.zip -O browser_daemon.zip && \
    unzip browser_daemon.zip && \
    rm -rf browser_daemon.zip

WORKDIR /scripts/home
RUN cp /home/openclaw/.bash_logout . && \
    cp /home/openclaw/.bashrc . && \
    cp /home/openclaw/.profile . && \
    mkdir .cache && \
    cd .cache && \
    cp -r /home/openclaw/.cache/ms-playwright .

ENV ONEAI_OPENAI_BASE_URL=https://oneai.17usoft.com/v1 \
    ONEAI_ANTHROPIC_BASE_URL=https://oneai.17usoft.com/anthropic

COPY ["supervisord.conf", "/etc/"]

WORKDIR /home/openclaw

ENTRYPOINT ["/entrypoint.sh"]